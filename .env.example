# GitHub Stars Manager Configuration

# GitHub (optional - used for higher API rate limits)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# LLM Provider - choose one
# openai | anthropic | deepseek
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative)
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#ANTHROPIC_MODEL=claude-sonnet-4-20250514
#LLM_PROVIDER=anthropic

# Deepseek (alternative, OpenAI-compatible API)
#DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#DEEPSEEK_MODEL=deepseek-v4-flash
#LLM_PROVIDER=deepseek

# Enrichment settings
ENRICH_BATCH_SIZE=10
ENRICH_CONCURRENCY=3

# Data storage
#DATA_DIR=data
#DB_PATH=data/stars.db

# CI/CD target user (for scheduled pipeline)
#STARS_USERNAME=OMIXEC

# Export
#DEFAULT_EXPORT_DIR=exports

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
# HuggingFace token (optional — for higher rate limits when downloading the local embedding model)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
